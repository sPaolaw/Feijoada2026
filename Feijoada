<!DOCTYPE html>
<html lang="pt-BR">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Feijoada Intercity</title>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;600;700;800;900&family=Lora:ital@1&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{--lj:#E85A00;--dk:#1a1a1a;--lt:#faf8f6}
body{font-family:'Montserrat',sans-serif;color:var(--dk);background:#fff}
.topbar{background:var(--dk);padding:12px 24px;display:flex;align-items:center;justify-content:space-between}
.topbar-right{font-size:10px;color:#777;letter-spacing:1.5px;text-transform:uppercase}
.hero{position:relative;height:480px;overflow:hidden;background:#111}
.hero-bg{position:absolute;inset:0;background:url('data:image/jpeg;base64,') center/cover no-repeat}
.hero-over{position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0.1),rgba(0,0,0,0.82));display:flex;flex-direction:column;align-items:center;justify-content:flex-end;padding:48px 24px;text-align:center}
.hero-badge{background:var(--lj);color:#fff;font-size:10px;font-weight:700;letter-spacing:2.5px;padding:5px 14px;border-radius:2px;margin-bottom:12px;text-transform:uppercase}
.hero-title{font-size:54px;font-weight:900;color:#fff;line-height:1;text-transform:uppercase;letter-spacing:-2px}
.hero-title b{color:var(--lj)}
.hero-sub{font-family:'Lora',serif;font-style:italic;color:#ddd;font-size:16px;margin:10px 0 22px}
.hero-cta{background:var(--lj);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-weight:800;font-size:13px;letter-spacing:2px;padding:14px 36px;border-radius:3px;cursor:pointer;text-transform:uppercase;transition:all .2s}
.hero-cta:hover{background:#bf4a00;transform:translateY(-2px)}
.strip{background:var(--lj);display:grid;grid-template-columns:repeat(4,1fr);text-align:center}
.si{padding:13px 8px;border-right:1px solid rgba(255,255,255,0.2)}
.si:last-child{border:none}
.si-l{font-size:9px;font-weight:700;letter-spacing:1.5px;color:rgba(255,255,255,0.65);text-transform:uppercase}
.si-v{font-size:14px;font-weight:800;color:#fff;margin-top:3px}
.galeria-section{padding:40px 24px}
.sec-badge{font-size:9px;font-weight:700;letter-spacing:2.5px;color:var(--lj);text-transform:uppercase;margin-bottom:6px}
.sec-title{font-size:26px;font-weight:900;text-transform:uppercase;line-height:1.1;margin-bottom:6px}
.dvd{width:36px;height:3px;background:var(--lj);margin:10px 0 20px}
.gal-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
.gal-grid img{width:100%;height:200px;object-fit:cover;border-radius:6px;display:block;background:#ddd}
.gal-grid img.wide{grid-column:span 2;height:270px}
.gal-caption{font-size:11px;color:#999;font-style:italic;text-align:center;margin-top:8px}
.insta-section{background:var(--dk);padding:36px 24px;text-align:center}
.insta-title{font-size:9px;font-weight:700;letter-spacing:2.5px;color:var(--lj);text-transform:uppercase;margin-bottom:6px}
.insta-heading{font-size:22px;font-weight:900;color:#fff;text-transform:uppercase;margin-bottom:6px}
.insta-sub{font-size:12px;color:#777;margin-bottom:18px}
.insta-grid{display:grid;grid-template-columns:repeat(3,1fr);grid-template-rows:repeat(2,1fr);gap:6px;max-width:600px;margin:0 auto 18px}
.insta-img{width:100%;aspect-ratio:1;object-fit:cover;border-radius:8px;display:block;background:#2a2a2a}
.insta-link{display:inline-flex;align-items:center;gap:8px;background:linear-gradient(135deg,#f09433,#e6683c,#dc2743,#cc2366,#bc1888);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-weight:700;font-size:12px;padding:10px 22px;border-radius:24px;text-decoration:none;transition:opacity .2s}
.insta-link:hover{opacity:.85}
.menu-section{background:var(--lt);padding:40px 24px}
.menu-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:16px}
.mi{background:#fff;border-left:3px solid var(--lj);padding:10px 12px;border-radius:0 5px 5px 0;box-shadow:0 1px 4px rgba(0,0,0,.05)}
.mi-name{font-size:13px;font-weight:700}
.mi-desc{font-size:11px;color:#aaa;margin-top:2px}
.destaque-box{margin-top:18px;background:#fff3ed;border-left:4px solid var(--lj);padding:12px 14px;border-radius:0 6px 6px 0;font-size:12px;color:#7c3b00;line-height:1.6}
.form-section{padding:40px 24px}
.form-card{background:#fff;border:1px solid #eee;border-radius:10px;padding:24px;box-shadow:0 2px 16px rgba(0,0,0,.07)}
.price-note{background:#fff3ed;border-left:4px solid var(--lj);padding:10px 12px;font-size:12px;color:#7c3b00;border-radius:0 5px 5px 0;margin-bottom:20px;line-height:1.8}
.fld{margin-bottom:14px}
.fld label{display:block;font-size:10px;font-weight:700;letter-spacing:1px;color:#888;text-transform:uppercase;margin-bottom:5px}
.fld input,.fld select,.fld textarea{width:100%;padding:11px 13px;border:1.5px solid #e0e0e0;border-radius:5px;font-family:'Montserrat',sans-serif;font-size:13px;color:var(--dk);background:#fff;outline:none;transition:border .15s}
.fld input:focus,.fld select:focus,.fld textarea:focus{border-color:var(--lj)}
.fld input[readonly]{background:var(--lt);font-weight:700;color:var(--lj)}
.r2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.contato-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:16px}
.copt{border:1.5px solid #e0e0e0;background:#fff;border-radius:6px;padding:12px 8px;text-align:center;cursor:pointer;transition:all .15s}
.copt:hover{border-color:var(--lj)}
.copt.on{border-color:var(--lj);background:#fff3ed}
.copt i{font-size:24px;display:block;margin-bottom:4px}
.copt-label{font-size:11px;font-weight:700;color:#888}
.copt.on .copt-label{color:var(--lj)}
.tbl-title{font-size:10px;font-weight:700;letter-spacing:1px;color:#888;text-transform:uppercase;margin-bottom:10px}
.tbl-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:5px;margin-bottom:8px}
.t{border:1.5px solid #e0e0e0;border-radius:5px;padding:6px 2px;text-align:center;cursor:pointer;background:#fff;transition:all .15s;position:relative}
.t:hover:not(.occ){border-color:var(--lj);background:#fff8f5}
.t.sel{border-color:var(--lj);background:#fff3ed}
.t.occ{background:#f5f5f5;cursor:not-allowed;opacity:0.4}
.t-n{font-size:12px;font-weight:800}
.t.sel .t-n{color:var(--lj)}
.t-c{font-size:8px;color:#bbb;margin-top:1px}
.t-cap-badge{position:absolute;top:2px;right:2px;font-size:7px;font-weight:700;border-radius:2px;padding:1px 3px;color:#aaa;background:#eee}
.t.sel .t-cap-badge{background:#ffd9c0;color:var(--lj)}
.legend{display:flex;gap:14px;flex-wrap:wrap;margin-bottom:8px}
.leg{display:flex;align-items:center;gap:5px;font-size:10px;color:#aaa}
.ldot{width:9px;height:9px;border-radius:2px;border:1.5px solid}
.cap-legend{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:18px}
.cap-leg{font-size:9px;color:#aaa;display:flex;align-items:center;gap:4px}
.cap-dot{width:16px;height:10px;border-radius:2px;font-size:7px;font-weight:700;display:flex;align-items:center;justify-content:center;color:#888}
.info-box{background:#eef4ff;border-left:4px solid #1565c0;padding:10px 12px;font-size:11px;color:#0d47a1;border-radius:0 5px 5px 0;margin-bottom:18px;line-height:1.6}
.btn-reservar{display:block;width:100%;background:var(--lj);color:#fff;border:none;font-family:'Montserrat',sans-serif;font-weight:900;font-size:16px;letter-spacing:2px;padding:17px;border-radius:6px;cursor:pointer;text-transform:uppercase;transition:all .2s;text-align:center}
.btn-reservar:hover{background:#bf4a00;transform:translateY(-2px);box-shadow:0 4px 16px rgba(232,90,0,0.3)}
.btn-reservar:active{transform:scale(.98)}
.btn-reservar:disabled{background:#ccc;cursor:not-allowed;transform:none;box-shadow:none}
.erro{display:none;background:#fdecea;border-left:4px solid #e53935;padding:10px 12px;font-size:12px;color:#b71c1c;border-radius:0 5px 5px 0;margin-top:12px}
.confirm-screen{display:none;background:#fff;border:2px solid #22c55e;border-radius:12px;padding:28px 20px;text-align:center;margin-top:20px}
.confirm-screen.on{display:block}
.confirm-icon{font-size:52px;color:#22c55e;display:block}
.confirm-title{font-size:20px;font-weight:900;color:#166534;margin-top:8px;text-transform:uppercase;letter-spacing:1px}
.confirm-cod{display:inline-block;background:#166534;color:#fff;font-size:22px;font-weight:900;letter-spacing:5px;padding:8px 20px;border-radius:5px;margin:12px 0}
.confirm-info{font-size:12px;color:#166534;background:#f0fff4;border-radius:6px;padding:12px 14px;text-align:left;line-height:2;margin-bottom:12px}
.wpp-btn{display:inline-flex;align-items:center;gap:8px;background:#25d366;color:#fff;border:none;font-family:'Montserrat',sans-serif;font-weight:700;font-size:12px;padding:10px 20px;border-radius:24px;cursor:pointer;text-decoration:none;transition:background .2s}
.wpp-btn:hover{background:#1da851}
.nova-btn{display:inline-flex;align-items:center;gap:6px;background:none;border:1.5px solid #ccc;color:#888;font-family:'Montserrat',sans-serif;font-weight:600;font-size:11px;padding:9px 16px;border-radius:24px;cursor:pointer;margin-left:8px;transition:all .2s}
.nova-btn:hover{border-color:var(--lj);color:var(--lj)}
.loading-bar{position:fixed;top:0;left:0;width:100%;height:3px;background:var(--lj);transform:scaleX(0);transform-origin:left;transition:transform .3s;z-index:999}
.loading-bar.show{animation:loadbar 1.5s ease infinite}
@keyframes loadbar{0%{transform:scaleX(0)}50%{transform:scaleX(0.7)}100%{transform:scaleX(1)}}
footer{background:var(--dk);padding:20px 24px;text-align:center}
footer p{font-size:10px;color:#555;letter-spacing:1px;text-transform:uppercase;margin-bottom:4px}
footer span{font-size:11px;color:var(--lj)}
@media(min-width:900px){
  .hero{height:560px}.hero-title{font-size:72px}
  .galeria-section,.menu-section,.form-section,.insta-section{padding:56px 10%}
  .gal-grid img{height:280px}.gal-grid img.wide{height:400px}
  .form-card{max-width:860px;margin:0 auto;padding:36px}
  .insta-grid{max-width:800px}.menu-grid{grid-template-columns:repeat(4,1fr)}
  .tbl-grid{grid-template-columns:repeat(10,1fr)}
  .topbar{padding:14px 10%}
}
@media(max-width:600px){
  .topbar{padding:10px 16px}.topbar-right{display:none}
  .hero{height:420px}.hero-title{font-size:36px;letter-spacing:-1px}
  .hero-over{padding:32px 16px}
  .strip{grid-template-columns:repeat(4,1fr)}
  .si-v{font-size:11px}.si-l{font-size:8px}
  .galeria-section,.menu-section,.form-section{padding:28px 16px}
  .insta-section{padding:28px 12px}
  .gal-grid img.wide{height:180px}.gal-grid img{height:130px}
  .r2{grid-template-columns:1fr}.menu-grid{grid-template-columns:1fr}
  .tbl-grid{grid-template-columns:repeat(5,1fr)}
  .insta-grid{grid-template-columns:repeat(3,1fr);max-width:100%}
  .form-card{padding:16px}.btn-reservar{font-size:14px;padding:15px}
}
</style>
  <!-- Firebase SDK -->
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-app-compat.js"></script>
  <script src="https://www.gstatic.com/firebasejs/9.23.0/firebase-firestore-compat.js"></script>
</head>
<body>

<div class="loading-bar" id="loading-bar"></div>

<div class="topbar">
  <div style="display:flex;align-items:center;gap:6px">
    <img src="data:image/jpeg;base64," alt="Intercity" style="height:36px;width:36px;object-fit:contain;border-radius:50%;flex-shrink:0">
    <div style="display:flex;flex-direction:column;line-height:1">
      <span style="font-family:Montserrat,sans-serif;font-weight:900;font-size:15px;color:#E85A00;letter-spacing:1.5px">INTERCITY</span>
      <span style="font-family:Montserrat,sans-serif;font-weight:500;font-size:8px;color:#fff;letter-spacing:3px;margin-top:1px">HOTELS</span>
    </div>
  </div>
  <div class="topbar-right">Aeroporto · Porto Alegre</div>
</div>

<div class="hero">
  <div class="hero-bg"></div>
  <div class="hero-over">
    <div class="hero-badge">Todo sábado · 12h às 15h</div>
    <div class="hero-title"><b>Feijoada</b><br>Intercity</div>
    <div class="hero-sub">Buffet completo com alma gaúcha</div>
    <button class="hero-cta" onclick="document.getElementById('reserva').scrollIntoView({behavior:'smooth'})">Reservar minha mesa agora</button>
  </div>
</div>

<div class="strip">
  <div class="si"><div class="si-l">Quando</div><div class="si-v">Todo Sábado</div></div>
  <div class="si"><div class="si-l">Horário</div><div class="si-v">12h às 15h</div></div>
  <div class="si"><div class="si-l">Por pessoa</div><div class="si-v">R$ 99,90</div></div>
  <div class="si"><div class="si-l">Taxa de serviço</div><div class="si-v">+10%</div></div>
</div>

<div class="galeria-section">
  <div class="sec-badge">O ambiente</div>
  <div class="sec-title">Restaurante & Espaço</div>
  <div class="dvd"></div>
  <div class="gal-grid">
    <img class="wide" src="https://media.staticontent.com/media/pictures/9471a9a4-ef60-41cd-8842-96d6b83b8fb0" alt="Buffet Intercity" onerror="this.src='data:image/jpeg;base64,'">
    <img src="https://media.staticontent.com/media/pictures/5735e9a0-640f-494e-a647-823a9662888c" alt="Piscina Intercity">
    <img src="https://media.staticontent.com/media/pictures/19f3af18-c81d-482e-aaf1-5025d7f12bab" alt="Fachada Intercity">
  </div>
  <div class="gal-caption">Intercity Aeroporto Porto Alegre — restaurante, piscina e área de lazer</div>
</div>

<div class="insta-section">
  <div class="insta-title">Nas redes sociais</div>
  <div class="insta-heading">@intercity.hotels</div>
  <div class="insta-sub">Veja o que está acontecendo e siga para mais novidades</div>
  <div class="insta-grid">
    <img class="insta-img" src="https://media.staticontent.com/media/pictures/9471a9a4-ef60-41cd-8842-96d6b83b8fb0" alt="Buffet">
    <img class="insta-img" src="https://media.staticontent.com/media/pictures/5735e9a0-640f-494e-a647-823a9662888c" alt="Piscina">
    <img class="insta-img" src="https://media.staticontent.com/media/pictures/234d2fc1-5316-44b6-9efd-1d0fb30d90cb" alt="Lobby">
    <img class="insta-img" src="https://media.staticontent.com/media/pictures/19f3af18-c81d-482e-aaf1-5025d7f12bab" alt="Fachada">
    <img class="insta-img" src="data:image/jpeg;base64," alt="Restaurante">
    <img class="insta-img" src="data:image/jpeg;base64," alt="Mesas">
  </div>
  <a class="insta-link" href="https://www.instagram.com/intercity.hotels/" target="_blank">
    <i class="ti ti-brand-instagram"></i> Ver mais no Instagram
  </a>
</div>

<div class="menu-section">
  <div class="sec-badge">O menu</div>
  <div class="sec-title">Buffet Completo<br>de Feijoada</div>
  <div class="dvd"></div>
  <div class="menu-grid">
    <div class="mi"><div class="mi-name"><i class="ti ti-bowl"></i> Feijoada completa</div><div class="mi-desc">Feijão preto com carnes variadas</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-bowl"></i> Arroz branco & Farofa</div><div class="mi-desc">Farofa crocante com bacon e ovos</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-leaf"></i> Couve refogada</div><div class="mi-desc">Alho e azeite, fininha</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-apple"></i> Laranja fatiada</div><div class="mi-desc">Para equilibrar o sabor</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-glass"></i> 1 Caipirinha inclusa</div><div class="mi-desc">Uma por pessoa</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-ice-cream"></i> Sobremesas da casa</div><div class="mi-desc">Seleção especial de sábado</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-friends"></i> Kids Club grátis</div><div class="mi-desc">Crianças entretidas e seguras</div></div>
    <div class="mi"><div class="mi-name"><i class="ti ti-swimming"></i> Piscina & Lareira</div><div class="mi-desc">Ambiente integrado ao jardim</div></div>
  </div>
  <div class="destaque-box"><strong>Restaurante renovado</strong> — integrado ao jardim, piscina e lareira. Aberto ao público. Capacidade para 145 pessoas.</div>
</div>

<div class="form-section" id="reserva">
  <div class="sec-badge">Garanta seu lugar</div>
  <div class="sec-title">Faça sua Reserva</div>
  <div class="dvd"></div>
  <div class="form-card" id="form-area">
    <div class="price-note">
      <strong>R$ 99,90 por pessoa</strong> + 10% de taxa de serviço<br>
      <span style="font-size:10px;color:#a06030">Pagamento no local · Horário: 12h às 15h</span>
    </div>
    <div class="fld"><label>Nome completo *</label><input type="text" id="f-nome" placeholder="Como prefere ser chamado(a)"></div>
    <div class="r2">
      <div class="fld"><label>WhatsApp *</label><input type="tel" id="f-tel" placeholder="(51) 9 0000-0000"></div>
      <div class="fld"><label>E-mail</label><input type="email" id="f-email" placeholder="seu@email.com"></div>
    </div>
    <div class="r2">
      <div class="fld"><label>Data (sábado) *</label><input type="date" id="f-data"></div>
      <div class="fld"><label>Nº de pessoas *</label>
        <select id="f-pess" onchange="updTotal()">
          <option value="1">1 pessoa</option><option value="2" selected>2 pessoas</option>
          <option value="3">3 pessoas</option><option value="4">4 pessoas</option>
          <option value="5">5 pessoas</option><option value="6">6 pessoas</option>
          <option value="7">7 pessoas</option><option value="8">8 pessoas</option>
        </select>
      </div>
    </div>
    <div class="fld"><label>Total a pagar no local (c/ taxa)</label><input id="f-total" readonly></div>
    <div class="fld" style="margin-bottom:8px"><label>Receber confirmação por *</label></div>
    <div class="contato-row">
      <div class="copt on" id="copt-wpp" onclick="selC('wpp')">
        <i class="ti ti-brand-whatsapp" style="color:#25d366"></i><div class="copt-label">WhatsApp</div>
      </div>
      <div class="copt" id="copt-email" onclick="selC('email')">
        <i class="ti ti-mail" style="color:#1565c0"></i><div class="copt-label">E-mail</div>
      </div>
    </div>
    <div class="tbl-title">Escolha sua mesa * <span style="font-weight:400;color:#bbb;font-size:9px">— número de lugares em cada mesa</span></div>
    <div class="tbl-grid" id="tgrid"></div>
    <div class="legend">
      <div class="leg"><div class="ldot" style="border-color:#E85A00;background:#fff3ed"></div>Selecionada</div>
      <div class="leg"><div class="ldot" style="border-color:#ddd;background:#fff"></div>Disponível</div>
      <div class="leg"><div class="ldot" style="border-color:#ccc;background:#f5f5f5"></div>Ocupada</div>
    </div>
    <div class="cap-legend">
      <div class="cap-leg"><div class="cap-dot" style="background:#dbeafe">2</div>2 lugares</div>
      <div class="cap-leg"><div class="cap-dot" style="background:#dcfce7">4</div>4 lugares</div>
      <div class="cap-leg"><div class="cap-dot" style="background:#fef9c3">6</div>6 lugares</div>
      <div class="cap-leg"><div class="cap-dot" style="background:#fce7f3">8</div>8 lugares</div>
    </div>
    <div class="fld"><label>Observações (opcional)</label><textarea id="f-obs" rows="2" placeholder="Aniversário, cadeirante, alergia alimentar, criança no Kids Club..."></textarea></div>
    <div class="info-box"><i class="ti ti-info-circle"></i> <strong>Como funciona:</strong> Após confirmar você recebe um código. Apresente-o na chegada. Pagamento no local.</div>
    <button class="btn-reservar" id="btn-res" onclick="confirmar()">✓ &nbsp;CONFIRMAR MINHA RESERVA</button>
    <div class="erro" id="erro-msg"></div>
  </div>
  <div class="confirm-screen" id="confirm-screen">
    <i class="ti ti-circle-check confirm-icon"></i>
    <div class="confirm-title">Reserva confirmada!</div>
    <div class="confirm-cod" id="conf-cod"></div>
    <div class="confirm-info" id="conf-info"></div>
    <p style="font-size:11px;color:#555;margin-bottom:14px">Anote ou tire um print do código. Apresente-o na chegada.</p>
    <a class="wpp-btn" id="wpp-link" href="#" target="_blank"><i class="ti ti-brand-whatsapp"></i> Salvar no WhatsApp</a>
    <button class="nova-btn" onclick="novaReserva()"><i class="ti ti-plus"></i> Nova reserva</button>
  </div>
</div>

<footer>
  <p>Intercity Aeroporto Porto Alegre · Rua Prof. Sarmento Barata, 360 — Navegantes, Porto Alegre</p>
  <span>intercityhoteis.com.br</span>
</footer>

<script>
const CAPS = {1:2,2:4,3:4,4:2,5:6,6:4,7:8,8:2,9:4,10:6,11:4,12:2,13:8,14:4,15:6,16:4,17:2,18:4,19:6,20:8,21:4,22:2,23:4,24:6,25:4,26:8,27:2,28:4,29:6,30:4,31:2,32:8,33:4,34:6,35:4};
const CAP_COLORS = {2:'#dbeafe',4:'#dcfce7',6:'#fef9c3',8:'#fce7f3'};
// ══════════════════════════════════════════════════
// FIREBASE FIRESTORE — banco de dados compartilhado
// ══════════════════════════════════════════════════
// CONFIGURAÇÃO: substitua com os dados do seu projeto Firebase
const FIREBASE_CONFIG = {
  apiKey:            "COLE_AQUI_SUA_API_KEY",
  authDomain:        "COLE_AQUI.firebaseapp.com",
  projectId:         "COLE_AQUI_SEU_PROJECT_ID",
  storageBucket:     "COLE_AQUI.appspot.com",
  messagingSenderId: "COLE_AQUI",
  appId:             "COLE_AQUI_SEU_APP_ID"
};
const COLECAO = 'reservas_feijoada';
let db_fire = null;
let selT=null, cMode='wpp', DB=[];

function showBar(){ document.getElementById('loading-bar').classList.add('show'); }
function hideBar(){ document.getElementById('loading-bar').classList.remove('show'); }

// Inicializar Firebase
function initFirebase(){
  try{
    if(!firebase.apps.length) firebase.initializeApp(FIREBASE_CONFIG);
    db_fire = firebase.firestore();
    return true;
  } catch(e){ console.log('Firebase não inicializado:', e); return false; }
}

// Carregar todas as reservas do Firestore
async function carregarDB(){
  try{
    if(!db_fire) initFirebase();
    const snap = await db_fire.collection(COLECAO).orderBy('timestamp','asc').get();
    DB = snap.docs.map(d => d.data());
    localStorage.setItem('fej_backup', JSON.stringify(DB));
  } catch(e){
    console.log('Firestore indisponível, usando cache local:', e);
    const local = localStorage.getItem('fej_backup');
    DB = local ? JSON.parse(local) : [];
  }
}

// Salvar uma reserva no Firestore
async function salvarDB(){
  localStorage.setItem('fej_backup', JSON.stringify(DB));
  try{
    if(!db_fire) initFirebase();
    // Salva apenas a última reserva adicionada (mais eficiente)
    const ultima = DB[DB.length - 1];
    if(ultima){
      await db_fire.collection(COLECAO).doc(ultima.id).set({
        ...ultima,
        timestamp: firebase.firestore.FieldValue.serverTimestamp()
      });
    }
  } catch(e){ console.log('Erro ao salvar no Firestore:', e); }
}

// Deletar uma reserva do Firestore
async function deletarDB(id){
  try{
    if(!db_fire) initFirebase();
    await db_fire.collection(COLECAO).doc(id).delete();
  } catch(e){ console.log('Erro ao deletar:', e); }
}

function genCod(){ return 'FEJ-'+Math.random().toString(36).substr(2,5).toUpperCase(); }
function calcValor(p){ return (p*99.9*1.1).toFixed(2).replace('.',','); }

function buildTbls(){
  const g=document.getElementById('tgrid'); g.innerHTML='';
  for(let i=1;i<=35;i++){
    const occ=DB.some(r=>r.mesa===i); const cap=CAPS[i];
    const d=document.createElement('div');
    d.className='t'+(occ?' occ':'');
    d.innerHTML=`<div class="t-cap-badge" style="background:${occ?'#eee':CAP_COLORS[cap]}">${cap}</div><i class="ti ti-armchair" style="font-size:13px;color:${occ?'#ccc':'#bbb'}"></i><div class="t-n">${i}</div><div class="t-c">${cap} lug.</div>`;
    if(!occ){ d.onclick=()=>{ document.querySelectorAll('.t').forEach(x=>x.classList.remove('sel')); d.classList.add('sel'); selT=i; }; }
    g.appendChild(d);
  }
}

function updTotal(){
  const p=parseInt(document.getElementById('f-pess').value)||2;
  document.getElementById('f-total').value='R$ '+calcValor(p);
}

function setDate(){
  const d=new Date(); const diff=(6-d.getDay()+7)%7||7; d.setDate(d.getDate()+diff);
  const s=d.toISOString().split('T')[0];
  document.getElementById('f-data').value=s;
  document.getElementById('f-data').min=s;
}

function selC(m){ cMode=m; document.getElementById('copt-wpp').classList.toggle('on',m==='wpp'); document.getElementById('copt-email').classList.toggle('on',m==='email'); }
function mostrarErro(msg){ const e=document.getElementById('erro-msg'); e.textContent='⚠ '+msg; e.style.display='block'; e.scrollIntoView({behavior:'smooth'}); }

async function confirmar(){
  document.getElementById('erro-msg').style.display='none';
  const nome=document.getElementById('f-nome').value.trim();
  const tel=document.getElementById('f-tel').value.trim();
  const email=document.getElementById('f-email').value.trim();
  const data=document.getElementById('f-data').value;
  const pess=parseInt(document.getElementById('f-pess').value);
  const obs=document.getElementById('f-obs').value.trim();
  if(!nome){ mostrarErro('Informe seu nome completo.'); return; }
  if(!tel){ mostrarErro('Informe seu WhatsApp.'); return; }
  if(cMode==='email'&&!email){ mostrarErro('Informe seu e-mail.'); return; }
  if(!selT){ mostrarErro('Escolha uma mesa no mapa acima.'); return; }
  const [y,m2,d2]=data.split('-'); const dataFmt=`${d2}/${m2}/${y}`;
  const total='R$ '+calcValor(pess);
  const cod=genCod();
  const res={id:cod,nome,tel,email,data:dataFmt,pess,mesa:selT,total,contato:cMode,obs,
    hora:new Date().toLocaleTimeString('pt-BR',{hour:'2-digit',minute:'2-digit'}),
    dataCad:new Date().toLocaleDateString('pt-BR')};

  const btn=document.getElementById('btn-res');
  btn.disabled=true; btn.textContent='Salvando reserva...';
  showBar();
  DB.push(res);
  await salvarDB();
  hideBar(); btn.disabled=false; btn.textContent='✓ CONFIRMAR MINHA RESERVA';
  buildTbls();
  document.getElementById('form-area').style.display='none';
  const cs=document.getElementById('confirm-screen'); cs.classList.add('on');
  document.getElementById('conf-cod').textContent=cod;
  document.getElementById('conf-info').innerHTML=`<strong>Nome:</strong> ${nome}<br><strong>Mesa:</strong> ${selT} (${CAPS[selT]} lugares)<br><strong>Data:</strong> ${dataFmt}<br><strong>Pessoas:</strong> ${pess}<br><strong>Total c/ taxa:</strong> ${total}${obs?'<br><strong>Obs:</strong> '+obs:''}`;
  const msg=`Olá ${nome.split(' ')[0]}! ✅ Sua reserva na *Feijoada Intercity* está confirmada!\n\n📋 *Código:* ${cod}\n🪑 Mesa: ${selT} (${CAPS[selT]} lugares)\n📅 Data: ${dataFmt}\n👥 ${pess} pessoa(s)\n💰 Total no local: ${total}\n\nApresente o código na chegada. Até sábado! 🍲\n\n— Feijoada Intercity`;
  document.getElementById('wpp-link').href=`https://wa.me/55${tel.replace(/\D/g,'')}?text=${encodeURIComponent(msg)}`;
  cs.scrollIntoView({behavior:'smooth'});
}

async function novaReserva(){
  selT=null;
  document.getElementById('form-area').style.display='block';
  document.getElementById('confirm-screen').classList.remove('on');
  ['f-nome','f-tel','f-email','f-obs'].forEach(id=>document.getElementById(id).value='');
  showBar();
  await carregarDB();
  hideBar();
  updTotal(); buildTbls();
  document.getElementById('reserva').scrollIntoView({behavior:'smooth'});
}

// Inicializa
(async ()=>{
  initFirebase();
  showBar();
  await carregarDB();
  hideBar();
  buildTbls(); updTotal(); setDate();
})();
</script>
</body>
</html>
